{
    "_comment": "Pipeline coniguration.",
    "delta_table": {
        "catalog": "CATALOG_NAME",
        "schema": "MY_SCHEMA",
        "table_name": "powerbi_refresh_history",
        "full_name_note": "Resolved as: {catalog}.{schema}.{table_name}"
    },
    "api": {
        "top_records_per_dataset": 60,
        "request_timeout_seconds": 30,
        "max_retries": 3, 
        "backoff_factor": 1.0,
        "inter_request_delay_seconds": 0.2,
        "max_concurrent_requests": 4
    },
    "extraction": {
        "incremental": true,
        "_comment": "when incremental is true, only records newer than the last stored start_time per dataset are processed. Set to false for a full re-extraction."
    },
    "secrets": {
        "scope": "powerbi-monitor",
        "tenant_id_key": "tenant-id",
        "client_id_key": "client-id",
        "client_secret_key": "client-secret"
    },
    "alerting": {
        "enabled": true,
        "teams_webhook_url": null,
        "check_failures": true,
        "check_duration_anomalies": true,
        "check_stale_data": true,
        "duration_anomaly_threshold_multiplier": 1.5,
        "duration_anomaly_rolling_window_days": 7,
        "staleness_threshold_hours": 26
    }
}